{
  "name": "backend",
  "version": "1.0.0",
  "description": "Fastify backend for the Brevet monorepo",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "fastify"
  ],
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.8",
    "fastify-tsconfig": "^3.0.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  }
}